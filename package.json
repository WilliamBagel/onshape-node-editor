{
  "name": "onshape-node-editor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build:app": "vite build",
    "build:app-dev": "vite build --mode development",
    "build:server": "tsc -p tsconfig.server.json && node ./scripts/copyServerAssets.cjs",
    "build": "run-p type-check \"build:app\" \"build:server\"",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "deploy:app": "npm run build:app && npx gh-pages -d dist/app",
    "deploy:app-dev": "npm run build:app-dev && npx gh-pages -d dist/app",
    "deploy:server": "npm run build:server && node ./scripts/deployServer.cjs",
    "scrape:docs": "node scripts/std-library-scrapper/scrapeFeatureScriptDocs.mjs",
    "scrape:docs-advanced": "node scripts/std-library-scrapper/scrapeFeatureScriptDocs-advanced.mjs",
    "scrape:docs-browser": "node scripts/std-library-scrapper/scrapeFeatureScriptDocs-advanced.mjs --browser",
    "organize:docs": "node scripts/std-library-scrapper/organizeLibrary.mjs",
    "scrape:all": "npm run scrape:docs && npm run organize:docs"
  },
  "dependencies": {
    "@azure/functions": "^4.16.0",
    "@rwh/keystrokes": "^1.5.6",
    "@vueform/multiselect": "^2.6.11",
    "color": "^5.0.3",
    "dotenv": "^17.4.2",
    "onshape-typescript-fetch": "github:toebes/onshape-typescript-fetch",
    "pnpm": "^10.34.1",
    "rete": "^2.0.6",
    "rete-area-plugin": "^2.1.5",
    "rete-connection-plugin": "^2.0.5",
    "rete-context-menu-plugin": "^2.0.6",
    "rete-engine": "^2.1.1",
    "rete-render-utils": "^2.0.3",
    "rete-scopes-plugin": "^2.1.1",
    "rete-structures": "^2.0.3",
    "rete-vue-plugin": "^2.1.2",
    "sass": "^1.100.0",
    "sass-loader": "^16.0.8",
    "three": "^0.156.1",
    "vite-plugin-svgr": "^4.5.0",
    "vue": "^3.5.35",
    "vue3-select": "^0.1.2"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.19.19",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.8.1",
    "adm-zip": "^0.5.17",
    "cheerio": "^1.2.0",
    "npm-run-all2": "^8.0.4",
    "puppeteer": "^24.43.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.5",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^3.3.3"
  }
}
